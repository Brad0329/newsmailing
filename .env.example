# 이 파일을 .env 로 복사 후 실제 값으로 채우세요.
# .env 는 절대 git 에 올리지 마세요 (.gitignore 에 등록됨).

# ───────────────────────────────────────────────
# Naver 검색 API (https://developers.naver.com/apps 에서 발급)
# ───────────────────────────────────────────────
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# ───────────────────────────────────────────────
# SMTP 설정 (회사 메일 서버)
# ───────────────────────────────────────────────
# 포트 465 → SMTP_USE_TLS=false  (SSL 직접 연결)
# 포트 587 → SMTP_USE_TLS=true   (STARTTLS)
SMTP_HOST=smtps.hiworks.com
SMTP_PORT=465
SMTP_USER=your_account@yourdomain.kr
SMTP_PASS=your_password_or_app_password
SMTP_FROM=your_account@yourdomain.kr
SMTP_USE_TLS=false

# ───────────────────────────────────────────────
# Flask (보통 기본값 그대로)
# ───────────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
